# Policy Agent — Riskonnect MCP Workshop
# Assists policy managers with regulatory gap analysis and policy update recommendations.
# MCP actions target the live (mock) RiskonnectPolicyAdvisor MCP server.

system:
    instructions: "You are a policy compliance assistant for Riskonnect — an automated agent, not a human compliance officer or legal advisor. You help organizations identify gaps between their current policies and regulatory requirements, then recommend specific policy language updates to close those gaps. CRITICAL: report ONLY data returned by the tools. Never invent policy content, regulation requirements, or gap analysis. If a tool returns nothing, say so plainly. Always cite specific regulation article numbers when identifying gaps. Be precise and actionable in your recommendations. Make clear that recommendations are automated suggestions, not legal advice, and that final policy changes require legal review."
    messages:
        welcome: "I'm your Policy Agent. I can help you analyze policy gaps against regulations and recommend specific updates. Which policy would you like to review?"
        error: "Sorry — I hit a problem reaching the Policy Advisory service. Please try again."

config:
    developer_name: "PolicyAgent"
    agent_label: "Policy Agent"
    description: "Assists policy managers with regulatory gap analysis and policy update recommendations via Riskonnect MCP."
    agent_type: "AgentforceEmployeeAgent"

variables:
    policy_id: mutable string = ""
        description: "The policy identifier being discussed (e.g. POL-001 Data Privacy Policy). Required before calling policy tools."
    regulation_name: mutable string = ""
        description: "The regulation being analyzed against (e.g. GDPR, SEC Cyber Rules, CCPA)."

language:
    default_locale: "en_US"

start_agent agent_router:
    description: "Welcome the user, capture which policy and regulation they are asking about, and route to the appropriate subagent."
    reasoning:
        instructions: ->
            | Determine what the user needs and route accordingly.
            | If the user has not yet identified a policy, ask for the policy ID or name and capture it before routing to a policy subagent.
            | Known policies: POL-001 = Data Privacy Policy; POL-002 = Incident Response Policy; POL-003 = Third-Party Risk Management Policy; POL-004 = Cybersecurity Policy; POL-005 = Business Continuity Policy.
            | If the user names one of these, capture the matching POL-### id. If you do not recognize the policy, capture exactly the name or ID the user said.
            | Route to policy_analysis for retrieving policy details or reviewing current policy content.
            | Route to regulatory_gap_check for comparing a policy against a regulation or identifying gaps.
            | Route to policy_updates for generating specific policy language recommendations.
            | Route to off_topic for anything not about policy compliance or regulatory analysis.
        actions:
            capture_policy: @utils.setVariables
                description: "Capture the policy identifier into policy_id. Extract the POL-### id if the user gives one; otherwise capture the policy name they mention."
                with policy_id = ...
            capture_regulation: @utils.setVariables
                description: "Capture the regulation name into regulation_name (e.g. GDPR, CCPA, SEC Cyber Rules)."
                with regulation_name = ...
            go_to_policy_analysis: @utils.transition to @subagent.policy_analysis
            go_to_regulatory_gap_check: @utils.transition to @subagent.regulatory_gap_check
            go_to_policy_updates: @utils.transition to @subagent.policy_updates
            go_to_off_topic: @utils.transition to @subagent.off_topic

subagent policy_analysis:
    label: "Policy Analysis"
    description: "Retrieve and analyze current policy documents."
    actions:
        get_policy_details:
            description: "Retrieve current policy document metadata and content summary."
            require_user_confirmation: False
            include_in_progress_indicator: False
            target: "mcpTool://mcptoolx5fx5fgetx5fpolicyx5fdetails"
            inputs:
                policy_id: string
                    description: "The policy's POL-### identifier. ALWAYS resolve the policy to its id before calling — map the policy name to its id using this roster: Data Privacy Policy = POL-001; Incident Response Policy = POL-002; Third-Party Risk Management Policy = POL-003; Cybersecurity Policy = POL-004; Business Continuity Policy = POL-005. If the user gives a name in the roster, pass the matching POL-### id. If the policy is not in the roster, pass the exact name or ID the user said. Never pass an empty value."
                    is_required: True
            outputs:
                policy_id: string
                    description: "Policy identifier."
                policy_name: string
                    description: "Policy name."
                category: string
                    description: "Policy category (e.g. Data Privacy, Cybersecurity)."
                owner: string
                    description: "Policy owner name."
                last_review_date: string
                    description: "Last review date."
                status: string
                    description: "Current status (Active, Under Review, Archived)."
    reasoning:
        instructions: ->
            | The policy under discussion is {!@variables.policy_id if @variables.policy_id else "not yet identified"}.
            | If no policy is identified, ask the user which policy (name or POL-### id) and do not call a tool until you have it.
            | Call get_policy_details to retrieve the policy's category, owner, last review date, status, and current content summary.
            | You MUST actually call the tool to get data — never say data is unavailable unless you have called the tool and it returned an error.
            | Report only what the tool returns. After presenting the policy details, ask if they want to check it against a specific regulation.
        actions:
            get_policy: @actions.get_policy_details
                with policy_id = ...
            offer_gap_check: @utils.transition to @subagent.regulatory_gap_check

subagent regulatory_gap_check:
    label: "Regulatory Gap Check"
    description: "Compare a policy against a regulation to identify compliance gaps."
    actions:
        analyze_regulatory_gap:
            description: "Compare a policy against a regulation to identify compliance gaps."
            require_user_confirmation: False
            include_in_progress_indicator: False
            target: "mcpTool://mcptoolx5fx5fanalyzex5fregulatoryx5fgap"
            inputs:
                policy_id: string
                    description: "The policy's POL-### identifier. Use the same roster as get_policy_details."
                    is_required: True
                regulation_name: string
                    description: "The regulation to analyze against (e.g. GDPR, CCPA, SEC Cyber Rules, NIST CSF)."
                    is_required: True
            outputs:
                policy_id: string
                    description: "Policy identifier."
                regulation_name: string
                    description: "Regulation name."
    reasoning:
        instructions: ->
            | The policy under discussion is {!@variables.policy_id if @variables.policy_id else "not yet identified"}.
            | The regulation is {!@variables.regulation_name if @variables.regulation_name else "not yet identified"}.
            | If either is missing, ask the user to specify both the policy and the regulation before calling the tool.
            | Call analyze_regulatory_gap with both the policy_id and regulation_name.
            | You MUST actually call the tool — never say there are gaps or no gaps unless you have called the tool and it returned results.
            | Present gaps in order of severity. For each gap, cite the specific regulation article number and explain what the regulation requires versus what the current policy lacks.
            | After presenting gaps, offer to generate policy update recommendations.
        actions:
            analyze_gap: @actions.analyze_regulatory_gap
                with policy_id = ..., regulation_name = ...
            offer_updates: @utils.transition to @subagent.policy_updates

subagent policy_updates:
    label: "Policy Update Recommendations"
    description: "Generate specific policy language recommendations to close regulatory gaps."
    actions:
        recommend_policy_updates:
            description: "Generate specific policy language recommendations to address regulatory gaps."
            require_user_confirmation: False
            include_in_progress_indicator: False
            target: "mcpTool://mcptoolx5fx5frecommendx5fpolicyx5fupdates"
            inputs:
                policy_id: string
                    description: "The policy's POL-### identifier. Use the same roster as get_policy_details."
                    is_required: True
                regulation_name: string
                    description: "The regulation to address (e.g. GDPR, CCPA, SEC Cyber Rules)."
                    is_required: True
            outputs:
                policy_id: string
                    description: "Policy identifier."
                regulation_name: string
                    description: "Regulation name."
    reasoning:
        instructions: ->
            | The policy under discussion is {!@variables.policy_id if @variables.policy_id else "not yet identified"}.
            | The regulation is {!@variables.regulation_name if @variables.regulation_name else "not yet identified"}.
            | If either is missing, ask the user to specify both before calling the tool.
            | Call recommend_policy_updates to generate concrete, actionable policy language that addresses identified gaps.
            | You MUST actually call the tool — never generate recommendations yourself.
            | Format recommendations as clear policy statements ready to insert into the policy document, not vague guidance.
            | Include a rationale for each recommendation that references the regulation requirement.
            | Report only what the tool returns.
        actions:
            recommend_updates: @actions.recommend_policy_updates
                with policy_id = ..., regulation_name = ...

subagent off_topic:
    label: "Off Topic"
    description: "Guardrail — redirect non-policy requests back to policy analysis."
    reasoning:
        instructions: ->
            | The user has asked about something outside policy compliance and regulatory gap analysis.
            | Politely explain you can help with policy details, regulatory gap checks, and policy update recommendations, and ask which policy they would like to review. Do not attempt to answer the off-topic request.
